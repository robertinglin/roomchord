{
  "name": "mosh",
  "version": "0.1.0",
  "description": "Mosh Matterhorn chat app with channels, private messages, presence, camera-capable rooms, and screen-share state.",
  "type": "commonjs",
  "main": "src/sdk-app.cjs",
  "exports": {
    ".": "./src/sdk-app.cjs",
    "./sdk-app": "./src/sdk-app.cjs",
    "./types": {
      "types": "./types.d.ts",
      "default": "./types.d.ts"
    }
  },
  "scripts": {
    "test": "node --test test/*.test.cjs",
    "coverage": "node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=70 --test-coverage-include=src/**/*.cjs test/*.test.cjs",
    "dev:frontend": "vite --config vite.config.ts --host 127.0.0.1 --port 42732 --strictPort",
    "build:frontend": "node shared/frontendCommand.cjs build .",
    "build:frontend:watch": "node shared/frontendCommand.cjs watch .",
    "serve:frontend": "vite preview --config vite.config.ts",
    "check:frontend": "tsc --project tsconfig.json",
    "check:fsd": "dependency-cruise --config .dependency-cruiser.cjs --validate --output-type err src",
    "build": "pnpm run build:frontend",
    "check": "pnpm run check:frontend && pnpm run check:fsd",
    "test:frontend": "vitest run --config vitest.config.ts src/app/chat-frontend.test.tsx src/features/messages/ui/MessageFeed.test.tsx",
    "dev": "matterhorn ./mosh.cjs mosh_live_room --serve dev"
  },
  "dependencies": {
    "@stylexjs/stylex": "^0.19.0",
    "matterhorn-sdk": "link:../matterhorn/packages/matterhorn-sdk",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "engines": {
    "node": ">=22.12"
  },
  "matterhorn": {
    "app": "./src/sdk-app.cjs"
  },
  "devDependencies": {
    "@stylexjs/babel-plugin": "^0.19.0",
    "@stylexjs/rollup-plugin": "^0.19.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "dependency-cruiser": "^17.4.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.8.0"
}
